Algoritmo TablaMultiplicar
    Definir n, i, resultado Como Entero
    
    
    Escribir "Ingrese un número: "
    Leer n
    
    
    Escribir " Tabla del ", n, ":"
  
    
    Para i <- 1 Hasta 20 Hacer
        resultado <- n * i
        Escribir n, " x ", i, " = ", resultado
    FinPara
    
    Escribir "Fin de la tabla."
FinAlgoritmo